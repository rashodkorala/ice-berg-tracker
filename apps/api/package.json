{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "Python FastAPI backend wrapper — scripts invoke uv-managed Python commands.",
  "scripts": {
    "dev": "uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "seed": "uv run python -m scripts.seed_db",
    "backfill": "uv run python -m scripts.backfill_history",
    "test": "uv run pytest",
    "lint": "uv run ruff check ."
  }
}
