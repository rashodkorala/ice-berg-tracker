# MongoDB Atlas connection string
# Create an M0 free cluster at https://cloud.mongodb.com and paste its SRV URI here.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=iceberg_tracker

# NOAA PolarWatch ERDDAP server (primary iceberg data source)
# Which live data source to fetch from:
#   metno — Norwegian Met Institute iceberg API (NW Atlantic / Newfoundland, live, weekly)
#   usnic — NOAA PolarWatch ERDDAP usnic_weekly_iceberg (Antarctic, historical)
DATA_SOURCE=metno

# --- met.no (used when DATA_SOURCE=metno) -------------------------------------
# https://api.met.no/weatherapi/iceberg/0.1/documentation — please include
# contact info in the User-Agent per met.no's usage policy.
METNO_USER_AGENT=IcebergTracker/0.1 (you@example.com)
METNO_SHIP_FILTER_KM=2.0
METNO_WEEKS=1

# --- NOAA PolarWatch (used when DATA_SOURCE=usnic) ----------------------------
ERDDAP_SERVER_URL=https://polarwatch.noaa.gov/erddap
ERDDAP_DATASET_ID=usnic_weekly_iceberg

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
