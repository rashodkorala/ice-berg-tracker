{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "API_ORIGIN",
    "NEXT_PUBLIC_API_ORIGIN",
    "MONGODB_URI",
    "MONGODB_DB",
    "ERDDAP_SERVER_URL",
    "ERDDAP_DATASET_ID",
    "API_HOST",
    "API_PORT",
    "CORS_ORIGINS",
    "LOG_LEVEL"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "seed": {
      "cache": false
    }
  }
}
